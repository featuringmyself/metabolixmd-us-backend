<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Approve Your Order - MetabolixMD</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', Arial, sans-serif;
        }

        body {
            background-color: #f5f5f5;
            color: #2E2E2E;
            line-height: 1.5;
        }

        .header {
            padding: 15px;
            margin: 10px 0;
            text-align: center;
            background-color: #fff;
        }

        .container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
            border-radius: 16px;
            overflow: hidden;
        }

        .status-bar {
            background-color: #365D56;
            color: white;
            padding: 8px 16px;
            text-align: center;
            font-size: 14px;
        }

        .heart-icon {
            display: flex;
            justify-content: center;
            margin: 24px 0;
        }

        .content {
            padding: 0 32px 32px;
            background-color: #EDF4F2;
            border-radius: 50px 50px 0 0;
            padding-top: 80px;
        }

        .main-title {
            font-size: 50px;
            line-height: 1.2;
            color: #2E2E2E;
            text-align: center;
            width: 80%;
            margin: 0 auto;
            display: block;
        }

        .main-title span {
            color: #005041;
        }

        .description {
            text-align: center;
            color: #4A4A4A;
            margin-top: 40px;
            margin-bottom: 32px;
            font-size: 16px;
            line-height: 1.6;
        }

        .action-section {
            text-align: center;
            margin: 32px 0;
        }

        .warning-box {
          margin: 0px auto;
            border: 2px solid #FD7823;
            border-style: dashed;
            border-radius: 23px;
            padding: 16px;
            text-align: center;
            font-size: 14px;
            font-weight: bolder;
            max-width: 460px;
        }

        .cta-button {
            display: inline-block;
            background-color: #365D56;
            color: white;
            padding: 12px 32px;
            border-radius: 100px;
            text-decoration: none;
            font-weight: 500;
            font-size: 16px;
            margin: 16px 0;
        }

        .support-section {
            background-color: #365D56;
            color: white;
            padding: 40px 32px;
            /* margin-top: 48px; */
            padding-bottom: 50px;
        }

        .support-title {
            font-size: 24px;
            margin-bottom: 24px;
            font-weight: 500;
        }

        .support-grid {
            display: flex;
            justify-content: space-between;
        }

        .support-text {
            width: 45%;
            font-size: 14px;
            color: rgba(255, 255, 255, 0.9);
        }

        .support-contact {
            text-align: right;
            font-size: 14px;
        }

        .support-contact a {
            color: white;
            text-decoration: underline;
        }


        .included-title {
            font-size: 32px;
            margin-bottom: 24px;
        }

        .included-description {
            color: #4A4A4A;
            margin-bottom: 32px;
            font-size: 16px;
        }

        .features-list {
            list-style: none;
        }

        .feature-item {
            display: flex;
            align-items: flex-start;
            margin-bottom: 24px;
        }

        .feature-icon {
            width: 32px;
            height: 32px;
            margin-right: 16px;
            color: #FD7823;
        }

        .feature-text {
            flex: 1;
        }

        .feature-text strong {
            display: block;
            margin-bottom: 4px;
        }

        .footer {
            background-color: #223d38;
            color: white;
            padding: 40px 30px 20px;
            text-align: center;
        }
        
        .footer-logo {
            margin-bottom: 20px;
            width: 20%;

        }
        
        .footer-tagline {
            font-size: 18px;
            margin-bottom: 30px;
            font-weight: 300;
        }
        
        .social-icons {
            margin-bottom: 30px;
        }
        
        .social-icon {
            display: inline-block;
            margin: 0 5px;
        }
        
        .footer-buttons {
            display: flex;
            justify-content: space-between;
            margin-bottom: 30px;
        }
        
        .footer-button {
            background-color: #365D56;
            color: white;
            padding: 10px 15px;
            border-radius: 25px;
            font-size: 12px;
            text-decoration: none;
            flex: 0 0 30%;
            text-align: center;
        }
        
        .footer-address {
            font-size: 12px;
            line-height: 150%;
            margin-bottom: 30px;
        }
        
        .footer-links {
            font-size: 12px;
            margin-bottom: 20px;
        }
        
        .footer-link {
            color: rgba(255, 255, 255, 0.6);
            
            margin: 0 5px;
        }
        
        .footer-disclaimer {
            font-size: 10px;
            margin-top: 20px;
            color: #FFFFFFB2;
            width: 70%;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .rating-section {
            background-color: #f1f5f3;
            padding: 40px 30px;
            /* text-align: center; */
            border-radius: 55px 55px 0 0;
            width: fit-content;
        }
        
        .rating-badge {
            width: 50px;
            height: 50px;
            border-radius: 50% ;
            margin: 0 auto 35px;
            line-height: 50px;
            font-size: 22px;
        }
        
        .rating-title {
            color: #0a513a;
            font-size: 28px;
            margin-bottom: 20px;
            line-height: 110%;
            font-weight: 500;
            letter-spacing: -3%;
        }
        
        .
    </style>
</head>
